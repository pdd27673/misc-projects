# GameTime Grid — Environment Variables

# ─── Core ──────────────────────────────────────────────────────
# Set to true to fetch live data from TheSportsDB (free, no key needed)
NEXT_PUBLIC_USE_LIVE_DATA=false

# ─── Premium Data Sources (optional) ───────────────────────────
# Gracenote/TMS API — broadcaster-grade sports event airings
# Sign up at: https://developer.tmsapi.com
# Adds: exact TV channel, lineup, station, region info per event
# TMS_API_KEY=your_tms_api_key_here

# TV Media API — sports TV schedule search by sport/team/league
# Sign up at: https://developer.tvmedia.ca
# Adds: broadcaster-oriented TV schedule coverage
# TVMEDIA_API_KEY=your_tvmedia_api_key_here

# SportDB.dev — alternative free fixture source
# Sign up at: https://sportdb.dev
# SPORTDB_API_KEY=your_sportdb_key_here

# ─── GitHub Pages (set automatically by GitHub Actions) ────────
# GITHUB_ACTIONS=true
# REPO_NAME=gametime-grid
